import SigmaR.StandingAlgebra_FormalCore

/-!
###############################################################################
# Admissibility Does Not Imply Truth
###############################################################################

Admissibility permits reasoning but does not assert that
any admissible claim is true.

This file introduces no axioms.
###############################################################################
-/

namespace SigmaR

/--
Admissibility of a configuration or reasoning pattern
does not imply truth of any conclusion.
-/
constant AdmissibilityDoesNotImplyTruth : Prop

end SigmaR
