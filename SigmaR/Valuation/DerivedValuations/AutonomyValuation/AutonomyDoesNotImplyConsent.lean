import SigmaR.StandingAlgebra_FormalCore

/-!
###############################################################################
# Autonomy Does Not Imply Consent
###############################################################################

Autonomy valuation does not imply consent, agreement,
or voluntary acceptance of conditions.

This prevents autonomy assessment from being misused
to infer consent to harm, constraint, or authority.

This file introduces no axioms.
###############################################################################
-/

namespace SigmaR

/--
Autonomy valuation does not imply consent.
-/
constant AutonomyDoesNotImplyConsent : Prop

end SigmaR
